# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (optional fallback; users can also paste their own key in the app)
OPENAI_API_KEY=your_openai_api_key

# Stock Images (Unsplash & Pexels)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
PEXELS_API_KEY=your_pexels_api_key

# External Role Check API
EXTERNAL_CHECK_USER_URL=https://api.example.com/check-user
EXTERNAL_API_KEY=your_external_api_key

# App Settings
APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_min_32_characters
NEXT_PUBLIC_AUTH_SERVICE_URL=your_auth_service_url
